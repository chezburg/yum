# =============================================================
# Instagram Recipe Extractor - Configuration Template
# Copy to `.env` and fill in values. NEVER commit `.env` to git.
# =============================================================

# --- Core ---
PORT=8000
DATABASE_URL=sqlite:////data/recipes.db
DATA_DIR=/data
LOG_LEVEL=INFO

# --- Export behavior ---
# Automatically export after a successful extraction
AUTO_EXPORT_ON_SUCCESS=true
# Comma-separated list: mealie, tandoor, markdown, json
EXPORT_TARGETS=markdown

# --- Instagram authentication (logged-in is the assumed default) ---
# Netscape-format cookies file exported from your browser while logged in.
# Used by yt-dlp and Instaloader for downloads/comments.
INSTAGRAM_COOKIE_FILE=/config/instagram_cookies.txt
# Your Instagram username (matching the cookie session; used by Instaloader)
INSTAGRAM_USERNAME=

# --- Speech-to-Text (configurable local OR API) ---
# Engine: local | openai | groq
WHISPER_ENGINE=local
# Model for local faster-whisper: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=small
# Device for local faster-whisper: auto | cpu | cuda
WHISPER_DEVICE=auto
# Compute type for local faster-whisper: default | int8 | float16
WHISPER_COMPUTE_TYPE=default
# API keys (only needed when engine is openai/groq)
OPENAI_API_KEY=
GROQ_API_KEY=

# --- OCR (configurable local OR API) ---
# Engine: paddleocr | tesseract | none
OCR_ENGINE=paddleocr
# Language for OCR
OCR_LANGUAGE=en
# Max keyframes to OCR per video (scene-change filtered)
OCR_MAX_FRAMES=40

# --- Vision analysis (optional stage, local OR API via LiteLLM) ---
# Enable/disable the vision (VLM) stage
VISION_ENABLED=false
# LiteLLM model string, e.g. gemini/gemini-2.5-flash, ollama/qwen2.5vl, gpt-4o
VISION_MODEL=
# Max keyframes sent to the VLM
VISION_MAX_FRAMES=8

# --- LLM Recipe Reconstruction (configurable local OR API via LiteLLM) ---
# LiteLLM model string. Examples:
#   gemini/gemini-2.5-flash        (Google AI Studio)
#   gpt-4o-mini                    (OpenAI)
#   anthropic/claude-sonnet-4-5    (Anthropic)
#   ollama/llama3.1                (local Ollama)
LLM_MODEL=gemini/gemini-2.5-flash
# API key for the chosen provider (not needed for Ollama)
LLM_API_KEY=
# Base URL override (needed for Ollama or self-hosted endpoints)
# LLM_API_BASE=http://ollama:11434

# --- Mealie export ---
MEALIE_URL=
MEALIE_API_TOKEN=

# --- Tandoor export ---
TANDOOR_URL=
TANDOOR_API_TOKEN=

# --- Markdown / Obsidian export ---
# Directory (mounted volume) where .md files are written
MARKDOWN_EXPORT_DIR=/export
