# =============================================================
# yum - Configuration Template
# Copy to `.env` and fill in values. NEVER commit `.env` to git.
#
# Almost all configuration now lives in the database and is
# managed through the web UI (Settings page). Only the bootstrap
# values below remain environment-based.
# =============================================================

# REQUIRED: encrypts secrets (API keys, Instagram session) stored in the
# database. Generate with:  openssl rand -hex 32
# Changing this key makes previously stored secrets unreadable.
SECRET_KEY=

# --- Optional bootstrap overrides (sensible defaults shown) ---
PORT=8000
DATABASE_URL=sqlite:////data/yum.db
DATA_DIR=/data
LOG_LEVEL=INFO

# --- Optional host bind-mount paths (used by docker-compose.yml) ---
# Where the database + config live on the host. Defaults to ./data if unset.
DATA_PATH=/docker/yum/data
# Where markdown exports are written on the host. Defaults to ./export if unset.
EXPORT_PATH=/docker/yum/export
